# Copy to .env.local and fill in your values.
# Get the Supabase keys from your Supabase project: Project Settings -> API.

# --- Public (sent to the browser) -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Used by app/sitemap.ts + app/robots.ts + dynamic OG images to build
# absolute URLs. Set to your deployed origin (e.g. https://yoursite.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enables in-browser error reporting via Sentry's HTTP ingest
# endpoint. Format: https://<publicKey>@<host>/<projectId>. Leave blank
# to disable telemetry entirely (errors only log to the console).
NEXT_PUBLIC_SENTRY_DSN=

# --- Server-only (NEVER expose to the browser) ------------------------------
# Service-role key — bypasses RLS. Required for the /admin panel reads.
# Project Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Admin gate. Only this email can unlock /admin (after an email-OTP step).
# Leave blank to disable admin entirely.
ADMIN_EMAIL=
